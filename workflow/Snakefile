import pandas as pd
import os
import shutil

configfile: "../configs/config.yaml"

samples_df = pd.read_csv(config["samples_sheet"], sep="\t")
SAMPLES    = samples_df["sample_id"].tolist()
BAM_FOR    = dict(zip(samples_df["sample_id"], samples_df["bam_path"]))
VCF_FOR    = dict(zip(samples_df["sample_id"], samples_df["vcf_path"]))

# Derive experiment name from samples sheet filename (e.g. test_samples.tsv → test)
_sheet_stem = os.path.splitext(os.path.basename(config["samples_sheet"]))[0]
if _sheet_stem.endswith("_samples"):
    _sheet_stem = _sheet_stem[: -len("_samples")]
EXPERIMENT = config.get("experiment_name", _sheet_stem)

OUTDIR  = os.path.join(config["output_dir"], EXPERIMENT)
GGTYPER = config.get("ggtyper", "../ggtyper")
THREADS = config.get("threads", 4)
CALLER  = config.get("caller", "manta")

SCRIPTS = os.path.join(workflow.basedir, "scripts")

include: "rules/merge_vcfs.smk"
include: "rules/prepare_variants.smk"
include: "rules/genotyping.smk"


rule all:
    input:
        f"{OUTDIR}/out_genotype_results.tsv.gz"


onsuccess:
    # Remove the profiles directory: ggtyper writes binary profile files there
    # that are not declared as rule outputs so temp() cannot clean them up.
    shutil.rmtree(f"{OUTDIR}/profiles", ignore_errors=True)
